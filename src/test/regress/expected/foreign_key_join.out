) PARTITION BY RANGE (c3);
CREATE TABLE pt2_1 PARTITION OF pt2 FOR VALUES FROM (1) TO (3);
CREATE TABLE pt2_2 PARTITION OF pt2 FOR VALUES FROM (3) TO (4);
