SELECT * FROM t1 JOIN t2 FOR KEY (c3) - > t1 (c2); -- error
ERROR:  syntax error at or near "-"
LINE 1: SELECT * FROM t1 JOIN t2 FOR KEY (c3) - > t1 (c2);
                                              ^
SELECT * FROM t1 JOIN t2 FOR KEY (c3) -/*comment*/> t1 (c2); -- error
ERROR:  syntax error at or near "-"
LINE 1: SELECT * FROM t1 JOIN t2 FOR KEY (c3) -/*comment*/> t1 (c2);
                                              ^
SELECT * FROM t1 JOIN t2 FOR KEY (c3) -> t1 (c2); -- error
ERROR:  there is no foreign key constraint on table "t2" (c3) referencing table "t1" (c2)
LINE 1: SELECT * FROM t1 JOIN t2 FOR KEY (c3) -> t1 (c2);
                                 ^
SELECT * FROM t1 JOIN t2 FOR KEY (c4) -> t1 (c1); -- error
ERROR:  there is no foreign key constraint on table "t2" (c4) referencing table "t1" (c1)
LINE 1: SELECT * FROM t1 JOIN t2 FOR KEY (c4) -> t1 (c1);
                                 ^
SELECT * FROM t1 JOIN t2 FOR KEY (c3,c4) -> t1 (c1,c2); -- error
ERROR:  there is no foreign key constraint on table "t2" (c3, c4) referencing table "t1" (c1, c2)
LINE 1: SELECT * FROM t1 JOIN t2 FOR KEY (c3,c4) -> t1 (c1,c2);
                                 ^
SELECT * FROM t1 JOIN t2 FOR KEY (c3) <- t1 (c1); -- error
ERROR:  there is no foreign key constraint on table "t1" (c1) referencing table "t2" (c3)
LINE 1: SELECT * FROM t1 JOIN t2 FOR KEY (c3) <- t1 (c1);
                                 ^
SELECT * FROM t1 JOIN t2 FOR KEY (c1) <- t1 (c3); -- error
ERROR:  column "c3" does not exist in referencing table
LINE 1: SELECT * FROM t1 JOIN t2 FOR KEY (c1) <- t1 (c3);
                                 ^
SELECT * FROM t1 JOIN t2 FOR KEY (c3) <- t1 (c2); -- error
ERROR:  there is no foreign key constraint on table "t1" (c2) referencing table "t2" (c3)
LINE 1: SELECT * FROM t1 JOIN t2 FOR KEY (c3) <- t1 (c2);
                                 ^
SELECT * FROM t1 JOIN t2 FOR KEY (c4) <- t1 (c1); -- error
ERROR:  there is no foreign key constraint on table "t1" (c1) referencing table "t2" (c4)
LINE 1: SELECT * FROM t1 JOIN t2 FOR KEY (c4) <- t1 (c1);
                                 ^
SELECT * FROM t1 JOIN t2 FOR KEY (c3,c4) <- t1 (c1,c2); -- error
ERROR:  there is no foreign key constraint on table "t1" (c1, c2) referencing table "t2" (c3, c4)
LINE 1: SELECT * FROM t1 JOIN t2 FOR KEY (c3,c4) <- t1 (c1,c2);
                                 ^
SELECT * FROM t1 AS a JOIN t2 AS b FOR KEY (c3) -> a (c2); -- error
ERROR:  there is no foreign key constraint on table "b" (c3) referencing table "a" (c2)
LINE 1: SELECT * FROM t1 AS a JOIN t2 AS b FOR KEY (c3) -> a (c2);
                                           ^
SELECT * FROM t2 JOIN t1 FOR KEY (c1) <- t2 (c3); -- ok
 c3 | c4 | c1 | c2 
----+----+----+----
  1 | 10 |  1 | 10
  3 | 30 |  3 | 30
(2 rows)

